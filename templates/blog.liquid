<div class="blog-page">
  <div class="page-hero">
    <div class="container">
      <p class="section-label">Journal</p>
      <h1 class="page-hero__title">{{ blog.title }}</h1>
      {%- if blog.articles_count > 0 -%}
        <p class="page-hero__meta">{{ blog.articles_count }} articles</p>
      {%- endif -%}
    </div>
  </div>

  <div class="container">
    {%- paginate blog.articles by 9 -%}
      {%- if blog.articles.size > 0 -%}
        <div class="blog-grid">
          {%- for article in blog.articles -%}
            <article class="blog-article-card" itemscope itemtype="https://schema.org/BlogPosting">
              {%- if article.image -%}
                <a href="{{ article.url }}" class="blog-article-card__img-wrap">
                  <img src="{{ article.image | image_url: width: 800, height: 500, crop: 'center' }}" alt="{{ article.title | escape }}" loading="lazy" class="blog-article-card__img" itemprop="image">
                </a>
              {%- else -%}
                <a href="{{ article.url }}" class="blog-article-card__img-wrap blog-article-card__img-wrap--placeholder"></a>
              {%- endif -%}
              <div class="blog-article-card__body">
                <div class="blog-article-card__meta">
                  <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">{{ article.published_at | date: '%B %d, %Y' }}</time>
                  {%- if article.author -%}
                    <span>· {{ article.author }}</span>
                  {%- endif -%}
                </div>
                <h2 class="blog-article-card__title" itemprop="headline">
                  <a href="{{ article.url }}">{{ article.title }}</a>
                </h2>
                <p class="blog-article-card__excerpt" itemprop="description">{{ article.excerpt_or_content | strip_html | truncate: 150 }}</p>
                <a href="{{ article.url }}" class="blog-article-card__link">
                  Read Article
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </article>
          {%- endfor -%}
        </div>
        {%- render 'pagination', paginate: paginate -%}
      {%- else -%}
        <!-- No Shopify Article records exist yet in this blog, so the journal
             showcases a set of SEO-written guides that live as static pages
             (templates/page.journal-*.liquid). Swap this block out once real
             blog Articles are published in Admin. -->
        {%- assign journal_posts = "How to Choose the Right Winter Jacket in 2026|/pages/journal-winter-jacket-guide|A complete buyer's guide to insulation, shells, and fit so you stay warm without overheating.|Jan 08, 2026;;How to Care for a Leather Jacket: The Complete Guide|/pages/journal-leather-jacket-care|Cleaning, conditioning, and storage tips that keep genuine leather supple for decades.|Jan 22, 2026;;Layering 101: How to Dress for Cold Weather Without the Bulk|/pages/journal-layering-guide|The base-mid-shell system stylists and mountaineers actually use, explained simply.|Feb 05, 2026;;Bomber vs. Parka vs. Puffer: Which Jacket Is Right for You|/pages/journal-jacket-types-guide|We break down warmth, weight, and style for the four most popular outerwear silhouettes.|Feb 19, 2026" | split: ";;" -%}
        <div class="blog-grid">
          {%- for post in journal_posts -%}
            {%- assign parts = post | split: "|" -%}
            <article class="blog-article-card" itemscope itemtype="https://schema.org/BlogPosting">
              <a href="{{ parts[1] }}" class="blog-article-card__img-wrap blog-article-card__img-wrap--placeholder"></a>
              <div class="blog-article-card__body">
                <div class="blog-article-card__meta">
                  <time itemprop="datePublished">{{ parts[3] }}</time>
                  <span>· Universal Jackets Team</span>
                </div>
                <h2 class="blog-article-card__title" itemprop="headline">
                  <a href="{{ parts[1] }}">{{ parts[0] }}</a>
                </h2>
                <p class="blog-article-card__excerpt" itemprop="description">{{ parts[2] }}</p>
                <a href="{{ parts[1] }}" class="blog-article-card__link">
                  Read Article
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </article>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>
