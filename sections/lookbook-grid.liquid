{% schema %}
{
  "name": "Lookbook Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "Seasonal Editorial" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Lookbook — Autumn / Winter 2025" },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Our latest editorial explores the intersection of urban grit and refined craftsmanship." },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Shop the Collection" },
    { "type": "url", "id": "cta_url", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text (for SEO)" },
        { "type": "url", "id": "link", "label": "Link (optional — e.g. a product or collection)" },
        { "type": "checkbox", "id": "tall", "label": "Tall tile", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook Grid",
      "blocks": [
        { "type": "look", "settings": { "tall": true } },
        { "type": "look" },
        { "type": "look" },
        { "type": "look" },
        { "type": "look", "settings": { "tall": true } },
        { "type": "look" },
        { "type": "look" },
        { "type": "look" },
        { "type": "look", "settings": { "tall": true } }
      ]
    }
  ]
}
{% endschema %}

<div class="content-page">
  <div class="container" style="max-width:900px;padding-top:64px;padding-bottom:64px;min-height:60vh;">
    <nav class="breadcrumb" style="margin-bottom:32px;">
      <ul class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="/">Home</a></li>
        <li class="breadcrumb__item">/</li>
        <li class="breadcrumb__item breadcrumb__item--current">Lookbook</li>
      </ul>
    </nav>
    {%- if section.settings.eyebrow != blank -%}
      <p class="section-label" style="margin-bottom:12px;">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 style="font-family:var(--font-serif);font-size:clamp(32px,4vw,52px);font-weight:400;margin-bottom:40px;line-height:1.2;">{{ section.settings.heading }}</h1>

    {%- if section.settings.intro != blank -%}
      <div class="rte" style="font-size:15px;line-height:1.8;color:var(--clr-mid);max-width:720px;">
        <p>{{ section.settings.intro }}</p>
      </div>
    {%- endif -%}

    <div class="lookbook-grid" style="margin-top:40px;">
      {%- for block in section.blocks -%}
        {%- assign hue = forloop.index0 | times: 40 -%}
        <div class="lookbook-grid__item{% if block.settings.tall %} lookbook-grid__item--tall{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" class="lookbook-grid__link">{%- endif -%}
          {%- if block.settings.image -%}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              srcset="{{ block.settings.image | image_url: width: 500 }} 500w, {{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1200 }} 1200w"
              alt="{{ block.settings.alt | default: section.settings.heading | escape }}"
              loading="lazy"
              class="lookbook-grid__img"
            >
          {%- else -%}
            <div class="lookbook-grid__placeholder" style="background:linear-gradient(160deg,hsl({{ hue }},20%,8%),hsl({{ hue | plus: 20 }},30%,15%));"></div>
          {%- endif -%}
          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_text != blank -%}
      <div style="text-align:center;margin-top:64px;">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn-primary">{{ section.settings.cta_text }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .lookbook-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .lookbook-grid__item,
  .lookbook-grid__link {
    height: 260px;
    display: block;
    border-radius: 6px;
    overflow: hidden;
  }
  .lookbook-grid__item--tall {
    height: 480px;
    grid-row: span 2;
  }
  .lookbook-grid__item--tall .lookbook-grid__link { height: 100%; }
  .lookbook-grid__img,
  .lookbook-grid__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 6px;
  }
  @media (max-width: 600px) {
    .lookbook-grid { grid-template-columns: repeat(2, 1fr); }
    .lookbook-grid__item--tall, .lookbook-grid__item--tall .lookbook-grid__link { height: 300px; }
    .lookbook-grid__item, .lookbook-grid__link { height: 160px; }
  }
</style>
