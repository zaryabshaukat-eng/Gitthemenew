{% schema %}
{
  "name": "Blog Preview",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "From Our Journal" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Style guides, care tips, and stories from behind the seams." },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "image_picker", "id": "side_image", "label": "Side Image" }
  ]
}
{% endschema %}

<section class="blog-preview section-spacing" data-aos="fade-up">
  <div class="container">
    <div class="blog-preview__inner">
      <!-- Image side -->
      <div class="blog-preview__image-col">
        {%- if section.settings.side_image -%}
          <img
            src="{{ section.settings.side_image | image_url: width: 800, height: 1000, crop: 'center' }}"
            alt="Journal"
            class="blog-preview__img"
            loading="lazy"
            width="800"
            height="1000"
          >
        {%- else -%}
          <div class="blog-preview__img-placeholder"></div>
        {%- endif -%}
        <div class="blog-preview__image-badge">
          <span>Since 2015</span>
        </div>
      </div>

      <!-- Content side -->
      <div class="blog-preview__content-col">
        <p class="section-label">Journal</p>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <p class="blog-preview__sub">{{ section.settings.subheading }}</p>

        <div class="blog-preview__articles">
          {%- assign blog_handle = section.settings.blog.handle | default: 'news' -%}
          {%- assign blog_obj = blogs[blog_handle] -%}
          {%- if blog_obj.articles.size > 0 -%}
            {%- for article in blog_obj.articles limit: 3 -%}
              <article class="blog-card">
                {%- if article.image -%}
                  <a href="{{ article.url }}" class="blog-card__img-wrap" tabindex="-1" aria-hidden="true">
                    <img src="{{ article.image | image_url: width: 600, height: 400, crop: 'center' }}" alt="{{ article.title | escape }}" loading="lazy" class="blog-card__img">
                  </a>
                {%- endif -%}
                <div class="blog-card__body">
                  <p class="blog-card__meta">{{ article.published_at | date: "%B %d, %Y" }}</p>
                  <h3 class="blog-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
                  <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 100 }}</p>
                  <a href="{{ article.url }}" class="blog-card__link">
                    Read More
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </div>
              </article>
            {%- endfor -%}
          {%- else -%}
            {%- assign sample_posts = "How to Choose the Right Winter Jacket in 2026|/pages/journal-winter-jacket-guide|A complete buyer's guide to insulation, shells, and fit so you stay warm without overheating.|Jan 08, 2026;;How to Care for a Leather Jacket: The Complete Guide|/pages/journal-leather-jacket-care|Cleaning, conditioning, and storage tips that keep genuine leather supple for decades.|Jan 22, 2026;;Layering 101: How to Dress for Cold Weather Without the Bulk|/pages/journal-layering-guide|The base-mid-shell system stylists and mountaineers actually use, explained simply.|Feb 05, 2026;;Bomber vs. Parka vs. Puffer: Which Jacket Is Right for You|/pages/journal-jacket-types-guide|We break down warmth, weight, and style for four popular outerwear silhouettes.|Feb 19, 2026" | split: ";;" -%}
            {%- for post in sample_posts -%}
              {%- assign parts = post | split: "|" -%}
              <article class="blog-card">
                <div class="blog-card__body">
                  <p class="blog-card__meta">{{ parts[3] }}</p>
                  <h3 class="blog-card__title"><a href="{{ parts[1] }}">{{ parts[0] }}</a></h3>
                  <p class="blog-card__excerpt">{{ parts[2] }}</p>
                  <a href="{{ parts[1] }}" class="blog-card__link">
                    Read More
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </div>
              </article>
            {%- endfor -%}
          {%- endif -%}
        </div>

        <a href="/blogs/{{ blog_handle }}" class="btn btn-outline">
          View All Articles
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
